# Copy to .env and adjust. .env is gitignored.

# Project data root (outputs + redis persistence). Flat top-level dir on the
# shared lab /data volume, matching existing project conventions.
DATA_ROOT=/data/expertasd_tts_pipeline

# Shared HuggingFace weight cache (already the machine's HF_HOME). Reused so
# weights are not duplicated on the 99%-full /data volume.
HF_CACHE_DIR=/data/hf_cache

# Host port the gateway listens on.
GATEWAY_PORT=8000

REDIS_URL=redis://redis:6379/0

# Empty for the 3 pilot systems (none are gated). Set for gated HF models later.
HF_TOKEN=

# Abort a worker's startup weight download if /data free space is below this
# many GB (protects the shared volume).
DATA_DISK_MIN_GB=5

# Recorded into every sample's metadata. Set to the pipeline git SHA in prod.
PIPELINE_VERSION=dev
